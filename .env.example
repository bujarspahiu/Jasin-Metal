# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string for your private VPS database
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL=postgresql://jasinuser:fjalekalim_i_forte@localhost:5432/jasinmetal

# ─── Server ──────────────────────────────────────────────────────────────────
# Port the Node.js server listens on (nginx proxies this port)
PORT=3001

# Set to "production" on the VPS — enables static file serving + SSL mode
NODE_ENV=production

# ─── Email (optional) ────────────────────────────────────────────────────────
# Resend API key for transactional emails (quote confirmations, orders, etc.)
# Leave empty to disable emails — the app works without it
RESEND_API_KEY=

# The "From" address shown in outgoing emails
RESEND_FROM_EMAIL=Jasin Metal <noreply@jasin-metal.com>

# Admin email that receives new quote requests and contact messages
ADMIN_EMAIL=info@jasin-metal.com
